{
  "version": 2,
  "buildCommand": "python manage.py collectstatic --noinput",
  "builds": [
    {
      "src": "MainProject/wsgi.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/static/Main/(.*)",
      "dest": "/Guest/static/Main/$1"
    },
    {
      "src": "/static/Admin/(.*)",
      "dest": "/Guest/static/Admin/$1"
    },
    {
      "src": "/(.*)",
      "dest": "MainProject/wsgi.py"
    }
  ]
}
